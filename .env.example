# Copy to .env and adjust. All values are optional (sensible defaults shown).

# Where all data/artifacts live (raw datasets, clips, predictions, logs).
# Set this to a shared/persistent volume to run from anywhere.
LANE_CACHE_DIR=./cache

# Cosmos model + vLLM server.
COSMOS_MODEL=nvidia/Cosmos-Reason2-32B
VLLM_HOST=localhost
VLLM_PORT=8000

# Path prefix the vLLM server sees for local media. When serving via Docker,
# mount LANE_CACHE_DIR at this path (see scripts/serve_vllm.sh).
VLLM_MEDIA_PATH_PREFIX=/workspace

# Hugging Face token (for BATON-Sample download); or use `huggingface-cli login`.
# HF_TOKEN=hf_xxx
